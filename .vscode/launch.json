{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "ZeGrapher",
            "type": "lldb-dap",
            "request": "launch",
            "program": "${workspaceFolder}/build-zg-debug/src/ZeGrapher",
            "cwd": "${workspaceFolder}/build-zg-debug",
            "preLaunchTask": "build-debug",
            // Disable debuginfod: on Arch, DEBUGINFOD_URLS is set system-wide and a
            // failed cache commit makes LLVM abort with "CachedFileStream was not
            // committed." Local debug builds already have full symbols.
            "initCommands": [
                "settings clear plugin.symbol-locator.debuginfod.server-urls"
            ]
        }
    ]
}
